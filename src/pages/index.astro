---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .filter(p => !p.data.draft)
  .sort((a, b) => {
    return new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf();
  });


---

<BaseLayout title="播客精读录 — 好播客，值得再读一次">
  <main class="flex-1">
    <!-- Hero -->
    <div class="max-w-[720px] mx-auto px-6 pt-16 pb-10">
      <h1 class="text-[40px] font-bold text-[#37352F] mb-2" style="letter-spacing: -0.02em;">播客精读录</h1>
      <p class="text-lg text-[#9B9A97]">好播客，值得再读一次。</p>
    </div>

    <!-- Sort Filter Bar -->
    <div class="max-w-[720px] mx-auto px-6 pb-4">
      <div class="flex items-center gap-1">
        <svg class="w-3.5 h-3.5 text-[#9B9A97] mr-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 6h18M6 12h12M9 18h6"/></svg>
        <button data-sort="published" class="sort-btn text-[12px] px-2.5 py-1 rounded-[3px] transition-colors">最新上架</button>
        <button data-sort="date" class="sort-btn sort-btn-active text-[12px] px-2.5 py-1 rounded-[3px] transition-colors">视频时间</button>
      </div>
    </div>

    <!-- Post List -->
    <div id="post-list" class="max-w-[720px] mx-auto px-6 pb-16">
      {posts.map((post, i) => {
        const formattedDate = new Date(post.data.date).toLocaleDateString('zh-CN', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
        });
        const publishedAt = post.data.published_at;
        return (
          <a href={`/posts/${post.id}`} class="group block post-item"
             data-published-at={publishedAt ? new Date(publishedAt).getTime() : new Date(post.data.date).getTime()}
             data-date={new Date(post.data.date).getTime()}
             data-published-ts={publishedAt ? new Date(publishedAt).toISOString() : ''}>
            <article class:list={[
              "flex gap-5 py-4 -mx-3 px-3 rounded-[4px] transition-colors hover:bg-[#F7F6F3]",
              i > 0 && "border-t border-[#E9E9E7]"
            ]}>
              {post.data.thumbnail && (
                <div class="hidden sm:block w-[120px] h-[80px] flex-shrink-0 rounded-[3px] overflow-hidden bg-[#F7F6F3]">
                  <img
                    src={post.data.thumbnail}
                    alt=""
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="flex-1 min-w-0">
                <h2 class="text-[15px] font-semibold text-[#37352F] leading-snug line-clamp-2 mb-1">
                  {post.data.title}
                  <span class="new-badge hidden ml-1.5 align-middle inline-block text-[10px] font-medium bg-[#D3E5EF] text-[#2E7D9A] px-1.5 py-0.5 rounded-[3px] leading-none" style="vertical-align: middle;">NEW</span>
                </h2>
                <div class="flex items-center gap-2 text-[12px] text-[#9B9A97] mb-2">
                  <span>{post.data.channel}</span>
                  {post.data.guest && (
                    <>
                      <span>·</span>
                      <span>{post.data.guest}</span>
                    </>
                  )}
                  <span>·</span>
                  <span>{formattedDate}</span>
                </div>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1">
                    {post.data.tags.slice(0, 3).map((tag: string) => (
                      <span class="bg-[#F1F1EF] text-[#64635F] text-[11px] px-2 py-0.5 rounded-[3px]">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </article>
          </a>
        );
      })}
    </div>
  </main>
</BaseLayout>

<style is:global>
  .sort-btn {
    color: #9B9A97;
    cursor: pointer;
    border: none;
    background: none;
    font-family: inherit;
  }
  .sort-btn:hover {
    background: #F7F6F3;
    color: #37352F;
  }
  .sort-btn-active {
    background: #F1F1EF;
    color: #37352F;
    font-weight: 500;
  }
</style>

<script>
  // NEW badge: show only for posts with the latest published_at date
  const items = document.querySelectorAll('.post-item');
  let maxDate = 0;
  const newItems = new Set<Element>();
  items.forEach(item => {
    const ts = item.getAttribute('data-published-ts');
    if (ts) {
      const d = new Date(ts).setHours(0,0,0,0);
      if (d > maxDate) maxDate = d;
    }
  });
  items.forEach(item => {
    const ts = item.getAttribute('data-published-ts');
    if (ts && new Date(ts).setHours(0,0,0,0) === maxDate) {
      newItems.add(item);
    }
  });

  function updateBadges(sortMode: string) {
    items.forEach(item => {
      const badge = item.querySelector('.new-badge');
      if (!badge) return;
      if (sortMode === 'published' && newItems.has(item)) {
        badge.classList.remove('hidden');
      } else {
        badge.classList.add('hidden');
      }
    });
  }
  // Default sort is 'date', so badges hidden on load
  updateBadges('date');

  const btns = document.querySelectorAll('.sort-btn');
  const list = document.getElementById('post-list');

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      btns.forEach(b => b.classList.remove('sort-btn-active'));
      btn.classList.add('sort-btn-active');

      const sortMode = btn.getAttribute('data-sort')!;
      const key = sortMode === 'date' ? 'data-date' : 'data-published-at';
      const sortItems = Array.from(list!.querySelectorAll('.post-item'));
      sortItems.sort((a, b) => {
        return Number(b.getAttribute(key)) - Number(a.getAttribute(key));
      });

      // Re-apply borders
      sortItems.forEach((item, i) => {
        const article = item.querySelector('article');
        if (article) {
          if (i > 0) {
            article.classList.add('border-t', 'border-[#E9E9E7]');
          } else {
            article.classList.remove('border-t', 'border-[#E9E9E7]');
          }
        }
        list!.appendChild(item);
      });

      updateBadges(sortMode);
    });
  });
</script>
