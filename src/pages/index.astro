---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="播客精读录 — AI 驱动的播客深度阅读">
  <main class="flex-1">
    <!-- Hero -->
    <div class="max-w-[680px] mx-auto px-6 pt-12 pb-8">
      <h1 class="text-[42px] font-bold tracking-tight leading-tight text-[#242424] mb-3" style="font-family: 'Source Serif 4', Georgia, serif;">播客精读录</h1>
      <p class="text-xl text-gray-500 leading-relaxed" style="font-family: 'Source Serif 4', Georgia, serif;">好播客，值得再读一次。</p>
    </div>

    <div class="border-t border-gray-200"></div>

    <!-- Post List -->
    <div class="max-w-[680px] mx-auto px-6 py-8">
      {posts.map((post, i) => {
        const formattedDate = new Date(post.data.date).toLocaleDateString('zh-CN', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
        });
        return (
          <article class:list={["group", i > 0 && "border-t border-gray-100 pt-8 mt-8"]}>
            <a href={`/posts/${post.id}`} class="flex gap-6">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 text-[13px] text-gray-500 mb-2">
                  <span>{post.data.channel}</span>
                  {post.data.guest && (
                    <>
                      <span>·</span>
                      <span>{post.data.guest}</span>
                    </>
                  )}
                </div>
                <h2 class="text-xl font-bold leading-snug text-[#242424] group-hover:text-[#1a8917] transition-colors mb-2 line-clamp-2" style="font-family: 'Source Serif 4', Georgia, serif;">
                  {post.data.title}
                </h2>
                <div class="flex items-center gap-3 text-[13px] text-gray-400 mt-3">
                  <span>{formattedDate}</span>
                  {post.data.reading_time && <span>· {post.data.reading_time} min read</span>}
                  {post.data.duration && <span>· 🎧 {post.data.duration}</span>}
                </div>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mt-3">
                    {post.data.tags.slice(0, 4).map((tag: string) => (
                      <span class="bg-gray-100 text-gray-600 text-[11px] px-2.5 py-0.5 rounded-full">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
              {post.data.thumbnail && (
                <div class="hidden sm:block w-[200px] h-[134px] flex-shrink-0 rounded overflow-hidden">
                  <img
                    src={post.data.thumbnail}
                    alt=""
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
              )}
            </a>
          </article>
        );
      })}
    </div>
  </main>
</BaseLayout>
