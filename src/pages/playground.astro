    .theme-muji .cta-btn { background: transparent; color: #786B5E; border: 1px solid #C8BFB3; border-radius: 0; font-size: 0.8rem; letter-spacing: 0.1em; }
    .theme-muji .tag { background: transparent; color: #A0978B; border: 1px solid #DDD6CC; border-radius: 0; font-size: 0.7rem; letter-spacing: 0.05em; }
    .theme-muji strong { color: #4A4A4A; font-weight: 600; }
    .theme-muji th { background: #F3F0EB; color: #4A4A4A; font-weight: 500; font-size: 0.8rem; letter-spacing: 0.05em; }
    .theme-muji .card-wrapper { box-shadow: none; border: none; border-radius: 0; border-bottom: 1px solid #E8E2D9; }
    .theme-muji .site-header { background: #F8F6F3; color: #786B5E; border-bottom: none; }
    .theme-muji .site-header a { color: #786B5E; font-weight: 400; letter-spacing: 0.1em; }
    .theme-muji .site-footer { background: #F8F6F3; color: #A0978B; font-size: 0.75rem; letter-spacing: 0.1em; }
    .theme-muji p { font-size: 0.95rem; line-height: 2; color: #4A4A4A; }

    /* ===== Theme: Ink 水墨 ===== */
    .theme-ink { --brand: #2C2C2C; --bg: #FAFAF8; --card: #FFFFFF; --text: #2C2C2C; --text-muted: #999; --quote-bg: #F5F5F2; }
    .theme-ink .masthead { background: transparent; color: #999; border-bottom: none; font-size: 0.8rem; }
    .theme-ink .section-title { background: transparent; color: #2C2C2C; font-size: 1.1rem; font-weight: 300; display: block; text-align: center; border-radius: 0; padding: 8px 0; border-bottom: none; letter-spacing: 0.3em; }
    .theme-ink .article-title { border-bottom: none; font-weight: 300; font-size: 1.8rem; letter-spacing: 0.08em; text-align: center; }
    .theme-ink blockquote { background: transparent; border-left: none; color: #666; font-style: normal; text-align: center; padding: 16px 32px; font-size: 1rem; position: relative; }
    .theme-ink blockquote::before { content: '「'; position: absolute; left: 8px; top: 12px; font-size: 1.5rem; color: #CCC; }
    .theme-ink blockquote::after { content: '」'; position: absolute; right: 8px; bottom: 8px; font-size: 1.5rem; color: #CCC; }
    .theme-ink .cta-btn { background: transparent; color: #2C2C2C; border: 1px solid #2C2C2C; border-radius: 0; font-size: 0.85rem; }
    .theme-ink .tag { background: transparent; color: #999; border: 1px solid #DDD; border-radius: 0; font-size: 0.75rem; }
    .theme-ink strong { color: #2C2C2C; font-weight: 600; }
    .theme-ink th { background: transparent; color: #2C2C2C; font-weight: 400; border-bottom: 2px solid #2C2C2C; }
    .theme-ink td { border-color: #E8E8E5; }
    .theme-ink .card-wrapper { box-shadow: none; border: none; border-radius: 0; }
    .theme-ink .site-header { background: #FAFAF8; color: #2C2C2C; border-bottom: none; }
    .theme-ink .site-header a { color: #2C2C2C; font-weight: 300; letter-spacing: 0.15em; }
    .theme-ink .site-footer { background: #FAFAF8; color: #BBB; }
    .theme-ink p { font-size: 1rem; line-height: 2; color: #3A3A3A; letter-spacing: 0.02em; }
    .theme-ink h1, .theme-ink h2, .theme-ink h3 { font-weight: 300; }

    /* ===== Theme: Mono 程序员风 ===== */
    .theme-mono { --brand: #24292E; --bg: #FAFBFC; --card: #FFFFFF; --text: #24292E; --text-muted: #6A737D; --quote-bg: #F6F8FA; }
    .theme-mono .masthead { background: #24292E; color: #79B8FF; font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace; font-size: 0.8rem; }
    .theme-mono .section-title { background: transparent; color: #24292E; font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace; font-size: 0.9rem; font-weight: 600; display: block; text-align: left; border-radius: 0; padding: 4px 0; border-bottom: 2px solid #E1E4E8; }
    .theme-mono .section-title::before { content: '## '; color: #6A737D; }
    .theme-mono .article-title { border-bottom: none; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-weight: 600; }
    .theme-mono blockquote { background: #F6F8FA; border-left: 4px solid #DFE2E5; color: #6A737D; font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace; font-size: 0.85rem; }
    .theme-mono .cta-btn { background: #2EA44F; color: white; border-radius: 6px; font-family: -apple-system, sans-serif; font-size: 0.85rem; }
    .theme-mono .tag { background: #DDF4FF; color: #0366D6; border-radius: 999px; font-family: 'SF Mono', monospace; font-size: 0.7rem; }
    .theme-mono strong { color: #24292E; }
    .theme-mono th { background: #F6F8FA; color: #24292E; font-weight: 600; font-size: 0.85rem; font-family: -apple-system, sans-serif; }
    .theme-mono td { border-color: #E1E4E8; font-size: 0.9rem; }
    .theme-mono .card-wrapper { box-shadow: none; border: 1px solid #E1E4E8; border-radius: 6px; }
    .theme-mono .site-header { background: #24292E; }
    .theme-mono .site-header a { color: #FFFFFF; font-weight: 500; }
    .theme-mono .site-footer { background: #FAFBFC; color: #6A737D; border-top: 1px solid #E1E4E8; font-family: 'SF Mono', monospace; font-size: 0.75rem; }
    .theme-mono p { font-size: 0.95rem; line-height: 1.75; }
  </style>
</head>
<body class="min-h-screen" style="background: #f0f2f5;">

  <!-- Sticky Theme Switcher -->
  <div class="theme-nav bg-white/90 shadow-sm">
    <div class="max-w-5xl mx-auto px-4 py-3 flex items-center gap-4 flex-wrap">
      <span class="font-bold text-sm text-gray-500">🎨 选择主题：</span>
      {themes.map(t => (
        <button
          class="theme-btn px-4 py-2 rounded-lg text-sm font-medium border cursor-pointer hover:shadow-md"
          data-theme={t.id}
          onclick={`switchTheme('${t.id}')`}
        >
          {t.name}
          <span class="text-xs text-gray-400 ml-1">({t.desc})</span>
        </button>
      ))}
    </div>
  </div>

  <!-- Preview Container -->
  <div id="preview" class="theme-classic">

    <!-- === SECTION 1: 首页预览 === -->
    <div class="max-w-5xl mx-auto px-4 mt-8 mb-4">
      <h2 class="text-lg font-bold text-gray-600 mb-2">📋 首页预览</h2>
    </div>

    <!-- Header -->
    <header class="site-header bg-[#0F4C81] text-white">
      <nav class="max-w-4xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="#" class="text-xl font-bold text-white">📖 播客精读录</a>
        <div class="flex gap-6 text-sm">
          <a href="#" class="text-white/80 hover:text-white">首页</a>
          <a href="#" class="text-white/80 hover:text-white">关于</a>
        </div>
      </nav>
    </header>

    <div class="max-w-4xl mx-auto px-4 py-8">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold mb-2" style="color: var(--brand)">播客精读录</h1>
        <p style="color: var(--text-muted)">让优质播客内容以更易消化的文字形式触达更多人</p>
      </div>

      <!-- Card Grid -->
      <div class="grid gap-6 md:grid-cols-2">
        {[1,2].map(() => (
          <div class="card-wrapper rounded-lg shadow-sm overflow-hidden" style="background: var(--card)">
            <div class="aspect-video overflow-hidden">
              <img src={samplePost.thumbnail} alt="" class="w-full h-full object-cover" />
            </div>
            <div class="p-5">
              <div class="flex items-center gap-2 text-xs mb-2" style="color: var(--text-muted)">
                <span>📺 {samplePost.channel}</span>
                <span>·</span>
                <span>{samplePost.date}</span>
              </div>
              <h2 class="font-bold text-lg leading-snug line-clamp-2" style="color: var(--text)">
                {samplePost.title}
              </h2>
              <div class="flex flex-wrap gap-1 mt-3">
                {samplePost.tags.slice(0, 3).map(tag => (
                  <span class="tag text-[10px] px-2 py-0.5 rounded-full">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- === SECTION 2: 文章详情预览 === -->
    <div class="max-w-5xl mx-auto px-4 mt-12 mb-4">
      <h2 class="text-lg font-bold text-gray-600 mb-2">📄 文章详情预览</h2>
    </div>

    <div class="max-w-4xl mx-auto px-4 pb-8">
      <article class="card-wrapper rounded-lg shadow-sm overflow-hidden" style="background: var(--card)">
        <!-- Masthead -->
        <div class="masthead text-center py-3 text-sm tracking-widest">
          {samplePost.volume}
        </div>

        <div class="px-6 py-8 md:px-12 md:py-12">
          <!-- Title -->
          <h1 class="article-title text-2xl md:text-3xl font-bold text-center leading-tight mb-4" style="color: var(--text)">
            {samplePost.title}
          </h1>

          <!-- Meta -->
          <div class="flex flex-wrap items-center justify-center gap-4 text-sm mb-8" style="color: var(--text-muted)">
            <span>📺 {samplePost.channel}</span>
            <span>🎙️ {samplePost.guest}</span>
            <span>📅 {samplePost.date}</span>
            <span>⏱️ {samplePost.reading_time} 分钟阅读</span>
          </div>

          <!-- Thumbnail -->
          <div class="hero-img mb-8 rounded-lg overflow-hidden">
            <img src={samplePost.thumbnail} alt="" class="w-full" />
          </div>

          <!-- CTA -->
          <div class="text-center mb-8">
            <a href="#" class="cta-btn inline-block px-6 py-2 rounded-full text-sm">🎧 收听原始播客</a>
          </div>

          <!-- Tags -->
          <div class="flex flex-wrap gap-2 justify-center mb-8">
            {samplePost.tags.map(tag => (
              <span class="tag text-xs px-3 py-1 rounded-full">{tag}</span>
            ))}
          </div>

          <!-- Sample Content -->
          <div class="space-y-6" style="color: var(--text); line-height: 1.85;">
            <blockquote class="pl-6 py-3 italic rounded-r-lg" style="color: var(--text-muted)">
              "设计不是在 AI 到来之后死去的，它是在进化。问题不是设计师会不会被取代，而是不使用 AI 的设计师会不会被使用 AI 的设计师取代。"
            </blockquote>

            <h2 class="text-center my-8">
              <span class="section-title">当设计遇见 AI</span>
            </h2>

            <p>在 Anthropic，Jenny Wen 领导着 Claude 的设计团队。她是最早一批将 AI 深度融入设计工作流的实践者之一。在这次与 Lenny 的深度对话中，Jenny 毫不保留地分享了她对设计未来的思考。</p>

            <p>传统的设计流程——调研、线框图、视觉稿、原型、测试——正在被 AI 压缩成一个更加流动的过程。<strong>Jenny 认为，设计师的核心价值正在从"像素推手"转向"体验架构师"</strong>。</p>

            <blockquote class="pl-6 py-3 italic rounded-r-lg" style="color: var(--text-muted)">
              "如果你不能用文字描述清楚一个体验，你也画不好它。AI 时代让我们重新发现了文字的力量。"
            </blockquote>

            <h2 class="text-center my-8">
              <span class="section-title">快问快答</span>
            </h2>

            <table class="w-full text-sm border-collapse rounded-lg overflow-hidden">
              <thead>
                <tr>
                  <th class="py-2 px-4 text-left">问题</th>
                  <th class="py-2 px-4 text-left">回答</th>
                </tr>
              </thead>
              <tbody>
                <tr class="border-b" style="background: var(--quote-bg)">
                  <td class="py-2 px-4">最推荐的设计工具？</td>
                  <td class="py-2 px-4">Figma + Claude</td>
                </tr>
                <tr class="border-b">
                  <td class="py-2 px-4">给新设计师的建议？</td>
                  <td class="py-2 px-4">先学会写作，再学设计工具</td>
                </tr>
                <tr class="border-b" style="background: var(--quote-bg)">
                  <td class="py-2 px-4">AI 会取代设计师吗？</td>
                  <td class="py-2 px-4">不会，但会重新定义角色</td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- Footer -->
          <div class="mt-12 pt-8 border-t text-center text-sm" style="color: var(--text-muted)">
            <p>📖 本文由 AI 基于播客逐字稿深度改写，仅供学习参考</p>
          </div>
        </div>
      </article>
    </div>

    <!-- Site Footer -->
    <footer class="site-footer bg-[#0F4C81] text-white/70 text-sm">
      <div class="max-w-4xl mx-auto px-4 py-6 text-center">
        <p>© 2026 播客精读录 — AI 驱动的播客深度阅读</p>
      </div>
    </footer>
  </div>

  <script is:inline>
    function switchTheme(id) {
      const preview = document.getElementById('preview');
      preview.className = `theme-${id}`;

      // Update bg
      const bgMap = { classic: '#f0f2f5', minimal: '#fff', warm: '#FDF8F0', magazine: '#f8f8f8', forest: '#F2F7EE', notion: '#FFFFFF', purple: '#F5F3FF', ocean: '#F0F9FF', zhihu: '#F6F6F6', sspai: '#F9F9F9', substack: '#FFFFFF', dark: '#0F172A' };
      document.body.style.background = bgMap[id] || '#f0f2f5';

      // Update header/footer for themes that override
      const header = document.querySelector('.site-header');
      const footer = document.querySelector('.site-footer');
      const hStyles = {
        classic: ['#0F4C81','#0F4C81'], minimal: ['white','white'], warm: ['#8B4513','#8B4513'],
        magazine: ['#1a1a1a','#1a1a1a'], forest: ['#2D5016','#2D5016'], notion: ['white','#F7F6F3'],
        purple: ['linear-gradient(135deg,#6C2BD9,#9F5AFF)','#1a1a2e'], ocean: ['linear-gradient(135deg,#0077B6,#00B4D8)','#023E58'],
        zhihu: ['#0066FF','#1A1A1A'], sspai: ['#D9363E','#333333'], substack: ['white','white'],
        dark: ['#0F172A','#0F172A']
      };
      const [hBg, fBg] = hStyles[id] || ['#0F4C81','#0F4C81'];
      header.style.background = hBg;
      footer.style.background = fBg;

      // Active btn
      document.querySelectorAll('.theme-btn').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.theme === id);
      });
    }

    // Default active
    document.addEventListener('DOMContentLoaded', () => switchTheme('classic'));
  </script>

</body>
</html>
