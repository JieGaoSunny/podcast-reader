    .theme-paper .site-header { background: #FAF6F0; color: #5C4033; border-bottom: 1px solid #E8DFD3; }
    .theme-paper .site-header a { color: #5C4033; }
    .theme-paper .site-footer { background: #FAF6F0; color: #8C7B6B; border-top: 1px solid #E8DFD3; }
    .theme-paper p { font-family: 'Palatino Linotype', 'Book Antiqua', Palatino, Georgia, serif; font-size: 1.05rem; line-height: 1.9; color: #3B3228; }

    /* ===== Theme: Muji 无印良品 ===== */
    .theme-muji { --brand: #786B5E; --bg: #F8F6F3; --card: #FFFFFF; --text: #4A4A4A; --text-muted: #A0978B; --quote-bg: #F3F0EB; }
    .theme-muji .masthead { background: transparent; color: #A0978B; border-bottom: none; font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase; }
