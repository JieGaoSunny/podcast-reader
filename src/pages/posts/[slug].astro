---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SubscribeCard from '../../components/SubscribeCard.astro';
import SubscribeFloat from '../../components/SubscribeFloat.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = (await getCollection('posts'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const frontmatter = post.data;
const formattedDate = new Date(frontmatter.date).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Group posts by channel
const grouped = new Map<string, typeof allPosts>();
for (const p of allPosts) {
  const ch = p.data.channel || '其他';
  if (!grouped.has(ch)) grouped.set(ch, []);
  grouped.get(ch)!.push(p);
}
---

<BaseLayout title={`${frontmatter.title} — 播客精读录`} description={frontmatter.title} ogImage={frontmatter.thumbnail}>
  <div class="flex-1 flex max-w-[1100px] mx-auto w-full">
    <!-- Sidebar -->
    <aside class="hidden lg:block w-[240px] flex-shrink-0 border-r border-[#E9E9E7] overflow-y-auto sticky top-11 h-[calc(100vh-44px)] py-4 px-3">
      <div class="text-[11px] font-medium text-[#9B9A97] uppercase tracking-wider mb-3 px-2">文章列表</div>
      {[...grouped.entries()].map(([channel, posts]) => (
        <div class="mb-3">
          <div class="text-[11px] text-[#9B9A97] px-2 mb-1 truncate">{channel}</div>
          <ul class="space-y-px">
            {posts.map((p) => {
              const isActive = p.id === post.id;
              return (
                <li>
                  <a
                    href={`/posts/${p.id}`}
                    class:list={[
                      "block text-[13px] leading-snug px-2 py-1 rounded-[3px] transition-colors truncate",
                      isActive
                        ? "bg-[#F1F1EF] text-[#37352F] font-medium"
                        : "text-[#9B9A97] hover:bg-[#F7F6F3] hover:text-[#37352F]"
                    ]}
                    title={p.data.title}
                  >
                    {p.data.guest ? `${p.data.guest}` : p.data.title.length > 30 ? p.data.title.slice(0, 30) + '…' : p.data.title}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      ))}
    </aside>

    <!-- Main content -->
    <main class="flex-1 min-w-0">
      <article class="max-w-[720px] mx-auto px-6 py-10">
        <!-- Breadcrumb -->
        <div class="flex items-center gap-1.5 text-[12px] text-[#9B9A97] mb-6">
          <a href="/" class="hover:text-[#37352F] transition-colors">首页</a>
          <span>/</span>
          <span class="text-[#37352F]">{frontmatter.channel}</span>
        </div>

        <!-- Title -->
        <h1 class="text-[32px] md:text-[40px] font-bold leading-tight text-[#37352F] mb-4" style="letter-spacing: -0.02em;">
          {frontmatter.title}
        </h1>

        <!-- Source link (right below title) -->
        <div class="mb-6">
          <a
            href={frontmatter.source_url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-[#2EAADC] text-white px-5 py-2.5 rounded-[3px] text-[14px] font-medium hover:opacity-90 transition-opacity shadow-md"
          >
            🎧 收听原始播客
          </a>
          <p class="mt-2 text-[11px] text-[#9B9A97] break-all">{frontmatter.source_url}</p>
        </div>

        <!-- Meta -->
        <div class="flex flex-wrap items-center gap-3 text-[13px] text-[#9B9A97] mb-6">
          {frontmatter.guest && <span>🎙️ {frontmatter.guest}</span>}
          <span>📅 {formattedDate}</span>
          {frontmatter.reading_time && <span>⏱️ {frontmatter.reading_time} 分钟阅读</span>}
          {frontmatter.duration && <span>🎧 {frontmatter.duration}</span>}
        </div>

        <!-- Tags -->
        {frontmatter.tags && frontmatter.tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5 mb-6">
            {frontmatter.tags.map((tag: string) => (
              <span class="bg-[#F1F1EF] text-[#64635F] text-[11px] px-2 py-0.5 rounded-[3px]">{tag}</span>
            ))}
          </div>
        )}

        <div class="border-b border-[#E9E9E7] mb-8"></div>

        <!-- Illustration -->
        {frontmatter.illustration && (
          <div class="mb-8 flex justify-center">
            <img src={frontmatter.illustration} alt="" class="w-[280px] h-auto opacity-90" loading="lazy" />
          </div>
        )}

        <!-- Thumbnail -->
        {frontmatter.thumbnail && (
          <div class="mb-8 rounded-[3px] overflow-hidden">
            <img src={frontmatter.thumbnail} alt={frontmatter.title} class="w-full" loading="lazy" />
          </div>
        )}



        <!-- Content -->
        <div class="prose prose-lg max-w-none
          prose-headings:text-[#37352F] prose-headings:font-semibold
          prose-h2:text-[20px] prose-h2:mt-10 prose-h2:mb-4 prose-h2:pb-1 prose-h2:border-b-2 prose-h2:border-[#37352F]
          prose-p:text-[#37352F] prose-p:leading-[1.8] prose-p:text-[16px]
          prose-blockquote:border-l-[3px] prose-blockquote:border-[#E9E9E7] prose-blockquote:bg-[#F7F6F3] prose-blockquote:rounded-r-[3px] prose-blockquote:pl-4 prose-blockquote:py-3 prose-blockquote:text-[#6B6B6B] prose-blockquote:not-italic
          prose-strong:text-[#37352F] prose-strong:font-semibold
          prose-a:text-[#2EAADC] prose-a:no-underline hover:prose-a:underline
          prose-li:text-[16px] prose-li:leading-[1.8]
          prose-table:text-sm
          prose-th:bg-[#F7F6F3] prose-th:text-[#37352F] prose-th:py-2 prose-th:px-4 prose-th:font-semibold
          prose-td:py-2 prose-td:px-4 prose-td:border-b prose-td:border-[#E9E9E7]
        ">
          <Content />
        </div>

        <!-- Subscribe Card -->
        <SubscribeCard />

        <!-- Footer -->
        <div class="mt-12 pt-6 border-t border-[#E9E9E7] text-center text-[13px] text-[#9B9A97]">
          <p>📖 本文由 AI 基于播客逐字稿深度改写，仅供学习参考</p>
          <p class="mt-1">来源：{frontmatter.channel} · <a href={frontmatter.source_url} target="_blank" class="text-[#2EAADC] hover:underline">原始视频</a></p>
        </div>

        <!-- Back -->
        <div class="mt-6 text-center">
          <a href="/" class="text-[#9B9A97] hover:text-[#37352F] transition-colors text-[13px]">← 返回首页</a>
        </div>
      </article>
    </main>
  </div>
  <!-- Subscribe Float -->
  <SubscribeFloat />
</BaseLayout>
