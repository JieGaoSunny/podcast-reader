---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = (await getCollection('posts'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const frontmatter = post.data;
const formattedDate = new Date(frontmatter.date).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Group posts by channel
const grouped = new Map<string, typeof allPosts>();
for (const p of allPosts) {
  const ch = p.data.channel || '其他';
  if (!grouped.has(ch)) grouped.set(ch, []);
  grouped.get(ch)!.push(p);
}
---

<BaseLayout title={`${frontmatter.title} — 播客精读录`} description={frontmatter.title} ogImage={frontmatter.thumbnail}>
  <div class="flex-1 flex max-w-[1336px] mx-auto w-full">
    <!-- Sidebar: Article tree -->
    <aside class="hidden lg:block w-[280px] flex-shrink-0 border-r border-gray-100 overflow-y-auto sticky top-14 h-[calc(100vh-56px)] py-6 px-4">
      <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4 px-2">所有文章</div>
      {[...grouped.entries()].map(([channel, posts]) => (
        <div class="mb-4">
          <div class="text-[11px] font-medium text-gray-400 px-2 mb-1.5 truncate">📺 {channel}</div>
          <ul class="space-y-0.5">
            {posts.map((p) => {
              const isActive = p.id === post.id;
              return (
                <li>
                  <a
                    href={`/posts/${p.id}`}
                    class:list={[
                      "block text-[13px] leading-snug px-2 py-1.5 rounded-md transition-colors truncate",
                      isActive
                        ? "bg-gray-100 text-[#242424] font-medium"
                        : "text-gray-500 hover:bg-gray-50 hover:text-gray-700"
                    ]}
                    title={p.data.title}
                  >
                    {p.data.guest ? `${p.data.guest}: ` : ''}{p.data.title.length > 40 ? p.data.title.slice(0, 40) + '…' : p.data.title}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      ))}
    </aside>

    <!-- Main content -->
    <main class="flex-1 min-w-0">
      <article class="max-w-[680px] mx-auto px-6 py-10">
        <!-- Meta -->
        <div class="flex items-center gap-2 text-[13px] text-gray-500 mb-4">
          <span>{frontmatter.channel}</span>
          {frontmatter.guest && (
            <>
              <span>·</span>
              <span>{frontmatter.guest}</span>
            </>
          )}
          <span>·</span>
          <span>{formattedDate}</span>
        </div>

        <!-- Title -->
        <h1 class="text-[32px] md:text-[40px] font-bold leading-tight text-[#242424] mb-4" style="font-family: 'Source Serif 4', Georgia, serif;">
          {frontmatter.title}
        </h1>

        <!-- Subtitle meta -->
        <div class="flex flex-wrap items-center gap-4 text-sm text-gray-400 mb-8 pb-8 border-b border-gray-100">
          {frontmatter.reading_time && <span>⏱️ {frontmatter.reading_time} 分钟阅读</span>}
          {frontmatter.duration && <span>🎧 原始时长 {frontmatter.duration}</span>}
          {frontmatter.guest_title && <span>💼 {frontmatter.guest_title}</span>}
        </div>

        <!-- Thumbnail -->
        {frontmatter.thumbnail && (
          <div class="mb-8 rounded-lg overflow-hidden">
            <img src={frontmatter.thumbnail} alt={frontmatter.title} class="w-full" loading="lazy" />
          </div>
        )}

        <!-- Source link -->
        <div class="mb-8">
          <a
            href={frontmatter.source_url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-[#1a8917] text-white px-5 py-2 rounded-full text-sm hover:bg-[#156d12] transition-colors"
          >
            🎧 收听原始播客
          </a>
        </div>

        <!-- Tags -->
        {frontmatter.tags && frontmatter.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-8">
            {frontmatter.tags.map((tag: string) => (
              <span class="bg-gray-100 text-gray-600 text-xs px-3 py-1 rounded-full">{tag}</span>
            ))}
          </div>
        )}

        <!-- Content -->
        <div class="prose prose-lg max-w-none
          prose-headings:text-[#242424] prose-headings:font-bold
          prose-h2:text-[22px] prose-h2:mt-12 prose-h2:mb-4
          prose-p:text-[#242424] prose-p:leading-[1.85] prose-p:text-[18px]
          prose-blockquote:border-l-[3px] prose-blockquote:border-[#242424] prose-blockquote:pl-5 prose-blockquote:italic prose-blockquote:text-gray-600
          prose-strong:text-[#242424] prose-strong:font-semibold
          prose-a:text-[#1a8917] prose-a:no-underline hover:prose-a:underline
          prose-li:text-[18px] prose-li:leading-[1.85]
          prose-table:text-sm
          prose-th:bg-gray-100 prose-th:text-[#242424] prose-th:py-2 prose-th:px-4 prose-th:font-semibold
          prose-td:py-2 prose-td:px-4 prose-td:border-b prose-td:border-gray-100
        " style="font-family: 'Source Serif 4', Georgia, serif;">
          <Content />
        </div>

        <!-- Footer -->
        <div class="mt-16 pt-8 border-t border-gray-100 text-center text-sm text-gray-400">
          <p>📖 本文由 AI 基于播客逐字稿深度改写，仅供学习参考</p>
          <p class="mt-1">来源：{frontmatter.channel} | <a href={frontmatter.source_url} target="_blank" class="underline">原始视频</a></p>
        </div>

        <!-- Back -->
        <div class="mt-8 text-center">
          <a href="/" class="text-[#1a8917] hover:underline text-sm">← 返回首页</a>
        </div>
      </article>
    </main>
  </div>
</BaseLayout>
