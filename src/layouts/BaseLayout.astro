---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = '播客精读录 — 让优质播客内容以更易消化的文字形式触达更多人', ogImage = '/og-image.png' } = Astro.props;

import '../styles/global.css';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-white text-[#242424] min-h-screen flex flex-col antialiased" style="font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;">
    <header class="border-b border-gray-200 sticky top-0 bg-white z-50">
      <nav class="max-w-[1336px] mx-auto px-6 h-14 flex items-center justify-between">
        <a href="/" class="text-xl font-bold text-[#242424] hover:opacity-80 transition-opacity">📖 播客精读录</a>
        <div class="flex items-center gap-5 text-sm text-gray-500">
          <a href="/" class="hover:text-[#242424] transition-colors">首页</a>
          <a href="/about" class="hover:text-[#242424] transition-colors">关于</a>
        </div>
      </nav>
    </header>

    <slot />

    <footer class="border-t border-gray-200 text-sm text-gray-400" style="font-family: 'Source Serif 4', Georgia, serif;">
      <div class="max-w-[1336px] mx-auto px-6 py-8 text-center">
        <p>© 2026 播客精读录</p>
        <p class="mt-1">Based on YouTube podcasts, rewritten by AI</p>
      </div>
    </footer>
  </body>
</html>
