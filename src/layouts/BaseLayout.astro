---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = '播客精读录 — 好播客，值得再读一次', ogImage = '/og-image.png' } = Astro.props;

import '../styles/global.css';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Serif+SC:wght@400;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-white text-[#37352F] min-h-screen flex flex-col antialiased" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', 'Noto Sans SC', sans-serif;">
    <header class="border-b border-[#E9E9E7] sticky top-0 bg-white z-50">
      <nav class="max-w-[900px] mx-auto px-6 h-11 flex items-center justify-between text-sm">
        <a href="/" class="font-semibold text-[#37352F] hover:opacity-70 transition-opacity flex items-center gap-1.5">
          <span class="text-base">📖</span>
          <span>播客精读录</span>
        </a>
        <div class="flex items-center gap-4 text-[#9B9A97]">
          <a href="/" class="hover:text-[#37352F] transition-colors">首页</a>
          <a href="/about" class="hover:text-[#37352F] transition-colors">关于</a>
        </div>
      </nav>
    </header>

    <slot />

    <script>
      import { inject } from '@vercel/analytics';
      inject();
    </script>

    <footer class="border-t border-[#E9E9E7] text-[13px] text-[#9B9A97] bg-[#F7F6F3]">
      <div class="max-w-[900px] mx-auto px-6 py-6 text-center">
        <p>© 2026 播客精读录 · 好播客，值得再读一次</p>
      </div>
    </footer>
  </body>
</html>
